# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# PostgreSQL
POSTGRES_USER=cartorio_user
POSTGRES_PASSWORD=cartorio_pass
POSTGRES_DB=cartorio_hub
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# URL de conexão (usada pelo SQLAlchemy)
DATABASE_URL=postgresql://cartorio_user:cartorio_pass@localhost:5432/cartorio_hub

# Aplicação
APP_ENV=development
APP_DEBUG=true
